# ── Supabase (safe to expose: anon key is public by design, protected by RLS) ──
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Groq (SECRET — server side only) ──
# Set this in Netlify → Site settings → Environment variables. It is read by the
# serverless function at netlify/functions/groq.mjs and is NEVER shipped to the browser.
# Do NOT add a VITE_ prefix to this one.
GROQ_API_KEY=your_groq_api_key

# Optional: local `vite dev` only. Lets the browser call Groq directly during
# development so you don't need `netlify dev`. Never set this in production —
# anything with a VITE_ prefix is bundled into the public client code.
# VITE_GROQ_API_KEY=your_groq_api_key

# Parent PIN (note: VITE_ vars are visible in the client bundle; this is a soft gate)
VITE_PARENT_PIN=1234
